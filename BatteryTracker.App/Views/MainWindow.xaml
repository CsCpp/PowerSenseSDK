<Window x:Class="BatteryTracker.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vmodels="clr-namespace:BatteryTracker.App.ViewModels"
        Title="BatteryTracker v1.0" Height="600" Width="1100"
        Background="#1E1E1E" Foreground="#E0E0E0">
    <!-- Темный фон окна -->

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <!-- Стиль кнопки из App.xaml подхватится автоматически -->
            <Button Content="📁 Открыть лог" Click="OpenFile_Click" Padding="15,7" Cursor="Hand"/>

            <TextBlock Text="{Binding StatusMessage}" 
                       VerticalAlignment="Center" 
                       Margin="20,0" 
                       FontSize="14" 
                       Foreground="#00BCF2"/>
            <!-- Голубой акцент для статуса -->
        </StackPanel>

        <!-- ИСПРАВЛЕНО: Background изменен на темный, убрана светлая рамка -->
        <Border x:Name="ChartHost" 
                Grid.Row="1" 
                Background="#252526" 
                BorderBrush="#3F3F46" 
                BorderThickness="1" 
                CornerRadius="8" 
                Padding="10">
            <!-- Сюда в коде вставляется график, он теперь будет на темном фоне -->
        </Border>
    </Grid>
</Window>